# =============================================================================
# Impact Observatory | مرصد الأثر — Environment Configuration Template
# =============================================================================
# Copy this file to .env and configure for your environment.
# All variables use the IO_ prefix (read by Pydantic Settings in app/config/settings.py).

# Application
IO_APP_NAME=Impact Observatory
IO_APP_VERSION=4.0.0
IO_ENVIRONMENT=development
IO_DEBUG=false
IO_LOG_LEVEL=INFO

# PostgreSQL + PostGIS Database
IO_POSTGRES_HOST=localhost
IO_POSTGRES_PORT=5432
IO_POSTGRES_DB=impact_observatory
IO_POSTGRES_USER=io_admin
IO_POSTGRES_PASSWORD=io_pilot_2026

# PostgreSQL Connection Pool
IO_POSTGRES_POOL_SIZE=20
IO_POSTGRES_MAX_OVERFLOW=10
IO_POSTGRES_POOL_PRE_PING=true
IO_POSTGRES_ECHO=false

# Neo4j Graph Database (V2 — not required for V1 in-memory mode)
IO_NEO4J_URI=bolt://localhost:7687
IO_NEO4J_USER=neo4j
IO_NEO4J_PASSWORD=io_graph_2026
IO_NEO4J_POOL_SIZE=50

# Redis (V2 — not required for V1 in-memory mode)
IO_REDIS_URL=redis://localhost:6379/0
IO_REDIS_MAX_CONNECTIONS=50
IO_REDIS_SOCKET_KEEPALIVE=true

# API Configuration
IO_API_PREFIX=/api/v1
IO_ALLOWED_ORIGINS=http://localhost:3000
IO_API_TIMEOUT=30

# External API Keys (optional)
# ACLED - Armed Conflict Location & Event Data
IO_ACLED_API_KEY=
IO_ACLED_API_EMAIL=
IO_ACLED_BASE_URL=https://api.acleddata.com

# =============================================================================
# ENVIRONMENT-SPECIFIC OVERRIDES
# =============================================================================

# DEVELOPMENT (uncomment)
# IO_ENVIRONMENT=development
# IO_DEBUG=true
# IO_LOG_LEVEL=DEBUG
# IO_POSTGRES_ECHO=true

# PILOT/STAGING (uncomment)
# IO_ENVIRONMENT=pilot
# IO_POSTGRES_HOST=pilot-db.example.com
# IO_NEO4J_URI=bolt://pilot-graph.example.com:7687

# PRODUCTION (uncomment)
# IO_ENVIRONMENT=production
# IO_LOG_LEVEL=WARNING
# IO_POSTGRES_HOST=prod-db.example.com
# IO_NEO4J_URI=bolt://prod-graph.example.com:7687
# IO_ALLOWED_ORIGINS=https://observatory.deevo.ai
